<p style="color: green"><%= notice %></p>

<% content_for :title, "Your notes" %>

<h1>Notes</h1>

<div id="notes">
  <% @notes.each do |note| %>
    <hr />
    <%= render note %>
    <p>
      <%= link_to "Show this note", note %>
    </p>
  <% end %>
</div>
<hr />

<%= link_to "New note", new_note_path %>
<%= link_to "Back to home", root_path %>
