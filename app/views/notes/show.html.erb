<p style="color: green"><%= notice %></p>

<%= render @note %>

<div>
  <%= link_to "Edit this note", edit_note_path(@note), class: 'text-blue-900' %> |
  <%= link_to "Back to notes", notes_path, class: 'text-blue-900' %>

  <%= button_to "Destroy this note", @note, class: 'text-red-900', method: :delete %>
</div>
